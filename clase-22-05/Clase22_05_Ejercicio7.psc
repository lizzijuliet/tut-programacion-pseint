Algoritmo Clase22_05_Ejercicio7
	
	Definir nota Como Cadena
	
	Escribir "Ingrese la nota final del alumno A, B, C, D o F:"
	Leer nota
	
	Segun nota Hacer
		
		"A", "a":
			Escribir "Excelente."
			
		"B", "b":
			Escribir "Muy bueno."
			
		"C", "c":
			Escribir "Bueno."
			
		"D", "d":
			Escribir "Insuficiente."
			
		"F", "f":
			Escribir "Reprobado."
			
		De Otro Modo:
			Escribir "Nota invalida."
			
	FinSegun
	
FinAlgoritmo