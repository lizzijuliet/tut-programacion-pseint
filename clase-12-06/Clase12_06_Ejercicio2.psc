Algoritmo Clase12_06_Ejercicio2
	
	Definir numero, resultado Como Entero
	
	Escribir "Ingrese un numero entero:"
	Leer numero
	
	resultado <- CalcularDoble(numero)
	
	Escribir "El doble de ", numero, " es: ", resultado
	
FinAlgoritmo


Funcion doble <- CalcularDoble(numero)
	
	Definir doble Como Entero
	
	doble <- numero * 2
	
FinFuncion