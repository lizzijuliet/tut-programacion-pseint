Algoritmo Clase2_Ejercicio3
	Definir num1, num2, producto Como Entero
	
	Escribir "Ingrese el primer numero entero:"
	Leer num1
	
	Escribir "Ingrese el segundo numero entero:"
	Leer num2
	
	producto <- num1 * num2
	
	Escribir "El producto de los dos numeros es: ", producto
	
FinAlgoritmo
