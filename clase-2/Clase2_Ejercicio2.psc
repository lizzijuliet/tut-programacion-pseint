Algoritmo Clase2_Ejercicio2
	Definir num1, num2, resta Como Entero
	
	Escribir "Ingrese el primer numero entero:"
	Leer num1
	
	Escribir "Ingrese el segundo numero entero:"
	Leer num2
	
	resta <- num1 - num2
	
	Escribir "La resta del primer numero menos el segundo es: ", resta
	
FinAlgoritmo
