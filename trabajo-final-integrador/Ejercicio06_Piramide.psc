Algoritmo Ejercicio06_Piramide
	
	Definir altura, fila, columna Como Entero
	
	Escribir "Ingrese la altura de la piramide:"
	Leer altura
	
	Para fila <- 1 Hasta altura Hacer
		
		Para columna <- 1 Hasta fila Hacer
			Escribir Sin Saltar columna, " "
		FinPara
		
		Escribir ""
		
	FinPara
	
FinAlgoritmo