Algoritmo Ejercicio05_Tabla_Multiplicar
	
	Definir n, i, resultado Como Entero
	
	Escribir "Ingrese un numero:"
	Leer n
	
	Escribir "Tabla de multiplicar del ", n
	
	Para i <- 1 Hasta 20 Hacer
		
		resultado <- n * i
		Escribir n, " x ", i, " = ", resultado
		
	FinPara
	
FinAlgoritmo